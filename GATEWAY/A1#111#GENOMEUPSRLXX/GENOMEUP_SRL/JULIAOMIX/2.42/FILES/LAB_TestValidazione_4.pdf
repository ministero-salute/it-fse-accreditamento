          <component>
            <section>
              <code code="29308-4" codeSystem="2.16.840.1.113883.6.1" codeSystemName="LOINC" displayName="Diagnosis"/>
              <title>Risultato</title>
              <text>
                <table border="1" width="100%">
                  <thead>
                    <tr>
                      <th>Campo</th>
