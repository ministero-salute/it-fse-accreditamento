      <component>
        <section>
          <code code="26436-6" codeSystem="2.16.840.1.113883.6.1" codeSystemName="LOINC" displayName="Laboratory studies"/>
          <title>Esami di laboratorio</title>
          <component>
            <section>
              <code code="62387-6" codeSystem="2.16.840.1.113883.6.1" codeSystemName="LOINC" displayName="Interventions Narrative"/>
              <title>Dettaglio Esame e Metodo Analitico</title>
              <text>
                <table border="1" width="100%">
                  <thead>
                    <tr>
                      <th>Campo</th>
                      <th>Valore</th>
                    </tr>
                  </thead>
                  <tbody>
                    <tr>
                      <td>Materiale esaminato</td>
                      <td>Espettorato</td>
                    </tr>
                    <tr>
                      <td>Quesito diagnostico</td>
                      <td>Sospetta infezione delle vie aeree inferiori</td>
                    </tr>
                    <tr>
                      <td>Test eseguito</td>
                      <td>Esame colturale in aerobiosi con identificazione di batterio isolato e antibiogramma</td>
                    </tr>
                    <tr>
                      <td>Approccio diagnostico</td>
                      <td>Esame microbiologico colturale con identificazione del batterio isolato e prova di sensibilità antibiotica</td>
                    </tr>
                    <tr>
                      <td>Regioni analizzate</td>
                      <td>Microrganismi coltivabili del campione ed eventuale profilo di sensibilità antibiotica</td>
                    </tr>
                    <tr>
                      <td>Data prelievo</td>
                      <td>2026-03-23</td>
                    </tr>
                    <tr>
                      <td>Data ricezione</td>
                      <td>2026-03-23</td>
                    </tr>
                  </tbody>
                </table>
                <paragraph ID="note-1">Limite del test: Il profilo di sensibilità antibiotica riportato si riferisce all'isolato identificato nel campione esaminato e deve essere interpretato nel contesto clinico del paziente.</paragraph>
                <paragraph ID="note-2">Annotazioni: Caso di test 4 LAB: batterio isolato da esame colturale diverso con una sola prova di resistenza agli antibiotici.</paragraph>
                <paragraph ID="note-3">S1 Staphylococcus aureus 100000/mL. Prova di sensibilità alla Penicillina G con esito resistente.</paragraph>
              </text>
              <entry typeCode="DRIV">
                <act classCode="ACT" moodCode="EVN">
                  <code code="62387-6" codeSystem="2.16.840.1.113883.6.1" codeSystemName="LOINC" displayName="Interventions Narrative"/>
