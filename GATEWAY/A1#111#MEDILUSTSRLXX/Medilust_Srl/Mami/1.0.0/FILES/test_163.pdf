			<component typeCode="COMP">
				<section ID="PRECEDENTI_ESAMI_ESEGUITI">
					<code code="30954-2" codeSystem="2.16.840.1.113883.6.1" codeSystemName="LOINC" displayName="Precedenti esami eseguiti"/>
					<title>Precedenti esami eseguiti</title>
					<text>
						<paragraph>Esame microscopico di campione di sangue - parassitologia</paragraph>
					</text>
				</section>
			</component>
			<component typeCode="COMP">
				<section ID="ESAME_OBIETTIVO">
					<code code="29545-1" codeSystem="2.16.840.1.113883.6.1" codeSystemName="LOINC" displayName="Esame obiettivo"/>
					<title>Esame obiettivo</title>
					<text>
						<paragraph>Azione cardiaca ritmica normo frequente. Rumore respiratorio fisiologico su tutto l&apos;ambito. Crepiti fissi alla base destra. Addome trattabile alla palpazione superficiale e profonda. Modesti edemi declivi</paragraph>
					</text>
				</section>
			</component>
			<component typeCode="COMP">
				<section ID="PRESTAZIONI">
					<code code="62387-6" codeSystem="2.16.840.1.113883.6.1" codeSystemName="LOINC" displayName="Interventi"/>
					<title>Prestazioni</title>
					<text>
						<paragraph>
							<content ID="PREST">Heart surgery operation</content>
						</paragraph>
						<table>
							<thead><tr><th>Procedura</th><th>Descrizione</th></tr></thead>
							<tbody>
								<tr><td>55122-6</td><td>Surgical operation note implants</td></tr>
							</tbody>
						</table>
					</text>
					
				</section>
			</component>
			<component typeCode="COMP">
				<section ID="CONFRONTO_CON_PRECEDENTI_ESAMI_ESEGUITI">
					<code code="93126-1" codeSystem="2.16.840.1.113883.6.1" codeSystemName="LOINC" displayName="Confronto con precedenti esami eseguiti"/>
					<title>Confronto con precedenti esami eseguiti</title>
					<text>
						<paragraph>Confronto con precedenti esami nella norma.</paragraph>
					</text>
				</section>
			</component>
			<component typeCode="COMP">
				<section ID="REFERTO">
					<code code="47045-0" codeSystem="2.16.840.1.113883.6.1" codeSystemName="LOINC" displayName="Referto"/>
					<title>Referto</title>
					<text>
						<paragraph>
							Referto nella norma per il quadro clinico in esame.
						</paragraph>
					</text>
				</section>
			</component>
			<component typeCode="COMP">
				<section ID="DIAGNOSI">
					<code code="29548-5" codeSystem="2.16.840.1.113883.6.1" codeSystemName="LOINC" displayName="Diagnosi"/>
					<title>Diagnosi</title>
					<text>
						<list>
							<item>
								<content ID="DIAG1">ALTERAZIONI DEL TEST RAPIDO DELLA GLICEMIA</content>
							</item>
						</list>
					</text>
					<entry>
						<observation classCode="OBS" moodCode="EVN">
							<code code="29308-4" codeSystem="2.16.840.1.113883.6.1" codeSystemName="LOINC" displayName="Diagnosi"/>
							<value xsi:type="CD" code="790.21" codeSystem="2.16.840.1.113883.6.103" codeSystemName="ICD9CM" displayName="ALTERAZIONI DEL TEST RAPIDO DELLA GLICEMIA"/>
						</observation>
					</entry>
				</section>
			</component>
			<component typeCode="COMP">
				<section ID="CONCLUSIONI">
					<code code="55110-1" codeSystem="2.16.840.1.113883.6.1" codeSystemName="LOINC" displayName="Conclusioni"/>
					<title>Conclusioni</title>
					<text>
						<paragraph>Quadro clinico stabile. Proseguire con monitoraggio.</paragraph>
					</text>
				</section>
			</component>
			<component typeCode="COMP">
				<section ID="SUGGERIMENTI_MEDICO_PRESCRITTORE">
					<code code="62385-0" codeSystem="2.16.840.1.113883.6.1" codeSystemName="LOINC" displayName="Suggerimenti per il medico prescrittore"/>
					<title>Suggerimenti per il medico prescrittore</title>
					<text>
						<paragraph>Si consiglia prosecuzione della terapia farmacologica in atto e rivalutazione a 30 giorni.</paragraph>
					</text>
				</section>
			</component>
			<component typeCode="COMP">
				<section ID="ACCERTAMENTI_E_CONTROLLI_CONSIGLIATI">
					<code code="80615-8" codeSystem="2.16.840.1.113883.6.1" codeSystemName="LOINC" displayName="Follow-up Consigliato"/>
					<title>Accertamenti e Controlli Consigliati</title>
					<text>
						<paragraph>
							Controllo glicemico a digiuno dopo 7 giorni.
						</paragraph>
					</text>
					<entry>
						<act classCode="ACT" moodCode="PRP">
							<code code="2340-8" codeSystem="2.16.840.1.113883.6.1" codeSystemName="LOINC" displayName="Glucose [Mass/volume] in Blood by Automated test strip"/>
						</act>
					</entry>
				</section>
			</component>
			<component typeCode="COMP">
				<section ID="TERAPIA_FARMACOLOGICA_CONSIGLIATA">
					<code code="93341-6" codeSystem="2.16.840.1.113883.6.1" codeSystemName="LOINC" displayName="Terapia farmacologica consigliata"/>
					<title>Terapia farmacologica consigliata</title>
					<text>
						<list>
							<item>LASIX*25MG 30 CPR</item>
						</list>
					</text>
					<entry>
						<substanceAdministration classCode="SBADM" moodCode="PRP">
							<text><reference value="#REF_MED"/></text>
							<effectiveTime xsi:type="IVL_TS">
								<low value="20220510121100+0100"/>
							</effectiveTime>
							<routeCode code="PO" codeSystem="2.16.840.1.113883.5.112" codeSystemName="RouteOfAdministration" displayName="Swallow,oral"/>
							<doseQuantity>
								<low value="20" unit="mg"/>
								<high value="30" unit="mg"/>
							</doseQuantity>
