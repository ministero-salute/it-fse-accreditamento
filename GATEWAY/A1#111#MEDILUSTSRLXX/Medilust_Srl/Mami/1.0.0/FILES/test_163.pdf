			<component typeCode="COMP">
				<section ID="STORIA_CLINICA">
					<code code="11329-0" codeSystem="2.16.840.1.113883.6.1" codeSystemName="LOINC" displayName="Anamnesi"/>
					<title>Anamnesi</title>
					<text>
						<paragraph>Anamnesi patologica remota negativa per patologie di rilievo.</paragraph>
					</text>
					<entry>
						<observation moodCode="EVN" classCode="OBS">
							<code code="75326-9" codeSystem="2.16.840.1.113883.6.1" codeSystemName="LOINC" displayName="Problem"/>
