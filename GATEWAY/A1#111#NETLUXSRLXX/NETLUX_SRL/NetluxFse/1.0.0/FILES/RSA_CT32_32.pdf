  <component>
    <structuredBody>
      <component>
        <section ID="Prestazioni">
          <code code="62387-6" codeSystem="2.16.840.1.113883.6.1" codeSystemName="LOINC" displayName="Interventi" />
          <title>Prestazioni</title>
          <text>
            <paragraph>Visita specialistica ambulatoriale</paragraph>
          </text>
          <entry>
            <act classCode="ACT" moodCode="EVN">
              <code code="89.7" codeSystem="2.16.840.1.113883.2.9.6.1.3" codeSystemName="ICD9CM" displayName="Visita specialistica" />
              <effectiveTime value="20260312094935" />
              <entryRelationship typeCode="COMP">
                <procedure classCode="PROC" moodCode="EVN">
                  <code code="89.7" codeSystem="2.16.840.1.113883.2.9.6.1.3" codeSystemName="ICD9CM" displayName="Visita specialistica" />
                </procedure>
              </entryRelationship>
            </act>
          </entry>
        </section>
      </component>
      <component>
        <section ID="Referto">
          <code code="47045-0" codeSystem="2.16.840.1.113883.6.1" codeSystemName="LOINC" displayName="Referto" />
          <title>Referto</title>
          <text>
            <paragraph>Il paziente presenta sindrome dolorosa lombare con limitazione funzionale. Si consiglia ciclo di fisioterapia riabilitativa con tecniche di terapia manuale e rieducazione posturale.</paragraph>
          </text>
        </section>
      </component>
      <component>
        <section ID="Quesito_Diagnostico">
          <code code="29299-5" codeSystem="2.16.840.1.113883.6.1" codeSystemName="LOINC" displayName="Motivo della visita" />
          <title>Quesito Diagnostico</title>
          <text>
            <paragraph>Sospetta lombalgia cronica con radicolopatia L5-S1.</paragraph>
          </text>
          <entry>
            <observation classCode="OBS" moodCode="EVN">
              <code code="29298-7" codeSystem="2.16.840.1.113883.6.1" codeSystemName="LOINC" displayName="Motivo della visita" />
              <value xsi:type="CD" code="724.2" codeSystem="2.16.840.1.113883.6.103" codeSystemName="ICD9-CM" displayName="Lombalgia" />
            </observation>
          </entry>
        </section>
      </component>
      <component>
        <section ID="Storia_Clinica">
          <code code="11329-0" codeSystem="2.16.840.1.113883.6.1" codeSystemName="LOINC" displayName="Storia Generale" />
          <title>Storia Clinica</title>
          <text>
            <paragraph>Anamnesi patologica prossima: lombalgia da 3 mesi. Anamnesi familiare: padre affetto da artrite reumatoide.</paragraph>
          </text>
          <entry>
            <observation classCode="OBS" moodCode="EVN">
              <code code="75326-9" codeSystem="2.16.840.1.113883.6.1" codeSystemName="LOINC" displayName="Problem" />
              <statusCode code="completed" />
              <effectiveTime>
                <low value="20251201" />
              </effectiveTime>
              <value xsi:type="CD" code="724.2" codeSystem="2.16.840.1.113883.6.103" codeSystemName="ICD9-CM" displayName="Lombalgia" />
            </observation>
          </entry>
          <entry>
            <organizer classCode="CLUSTER" moodCode="EVN">
              <code code="10157-6" codeSystem="2.16.840.1.113883.6.1" codeSystemName="LOINC" displayName="Storie di malattie di membri familiari" />
              <statusCode code="completed" />
              <subject>
                <relatedSubject classCode="PRS">
                  <code code="FTH" codeSystem="2.16.840.1.113883.5.111" codeSystemName="RoleCode" displayName="Padre" />
                  <subject>
                    <administrativeGenderCode code="M" codeSystem="2.16.840.1.113883.5.1" codeSystemName="HL7 AdministrativeGender" />
                  </subject>
                </relatedSubject>
              </subject>
              <component>
                <observation classCode="OBS" moodCode="EVN">
                  <code code="75315-2" codeSystem="2.16.840.1.113883.6.1" codeSystemName="LOINC" displayName="Condizione" />
                  <statusCode code="completed" />
                  <effectiveTime>
                    <low value="20200101" />
                  </effectiveTime>
                  <value xsi:type="CD" code="714.0" codeSystem="2.16.840.1.113883.6.103" codeSystemName="ICD9-CM" displayName="Artrite reumatoide" />
                </observation>
              </component>
            </organizer>
          </entry>
          <component>
            <section ID="Allergie">
              <code code="48765-2" codeSystem="2.16.840.1.113883.6.1" codeSystemName="LOINC" displayName="Allergie e/o Reazioni Avverse" />
              <title>Allergie</title>
              <text>
                <paragraph>Allergia a Penicillina.</paragraph>
              </text>
              <entry>
                <act classCode="ACT" moodCode="EVN">
                  <code nullFlavor="NA" />
                  <statusCode code="active" />
                  <effectiveTime>
                    <low value="20200101" />
                  </effectiveTime>
                  <entryRelationship typeCode="SUBJ">
                    <observation classCode="OBS" moodCode="EVN">
                      <code code="52473-6" codeSystem="2.16.840.1.113883.6.1" codeSystemName="LOINC" displayName="Allergia o causa della reazione" />
                      <statusCode code="completed" />
                      <effectiveTime>
                        <low value="20200101" />
                      </effectiveTime>
                      <value xsi:type="CD" code="DALG" codeSystem="2.16.840.1.113883.5.4" codeSystemName="ObservationIntoleranceType" displayName="Drug allergy" />
                      <participant typeCode="CSM">
                        <participantRole classCode="MANU">
                          <playingEntity classCode="MMAT">
                            <code code="J01CE01" codeSystem="2.16.840.1.113883.6.73" codeSystemName="ATC" displayName="Penicillina" />
                          </playingEntity>
                        </participantRole>
                      </participant>
                    </observation>
                  </entryRelationship>
                </act>
              </entry>
            </section>
          </component>
          <component>
            <section ID="Terapia_Farmacologica_in_atto">
              <code code="10160-0" codeSystem="2.16.840.1.113883.6.1" codeSystemName="LOINC" displayName="Uso di farmaci" />
              <title>Terapia farmacologica in atto</title>
              <text>
                <paragraph>Paracetamolo 1000mg al bisogno.</paragraph>
              </text>
              <entry>
                <substanceAdministration classCode="SBADM" moodCode="EVN">
                  <statusCode code="completed" />
                  <consumable>
                    <manufacturedProduct>
                      <manufacturedMaterial>
                        <code code="N02BE01" codeSystem="2.16.840.1.113883.6.73" codeSystemName="ATC" displayName="Paracetamolo" />
                      </manufacturedMaterial>
                    </manufacturedProduct>
                  </consumable>
                </substanceAdministration>
              </entry>
            </section>
          </component>
        </section>
      </component>
      <component>
        <section ID="Precedenti_Esami_Eseguiti">
          <code code="30954-2" codeSystem="2.16.840.1.113883.6.1" codeSystemName="LOINC" displayName="Test diagnostici e/o dati di laboratorio rilevanti" />
          <title>Precedenti Esami Eseguiti</title>
          <text>
            <paragraph>RX rachide lombosacrale eseguita in data 01/11/2025: protrusione discale L5-S1.</paragraph>
          </text>
          <entry>
            <observation classCode="OBS" moodCode="EVN">
              <code code="30954-2" codeSystem="2.16.840.1.113883.6.1" codeSystemName="LOINC" displayName="Test diagnostici rilevanti" />
              <statusCode code="completed" />
            </observation>
          </entry>
        </section>
      </component>
      <component>
        <section ID="Esame_Obiettivo">
          <code code="29545-1" codeSystem="2.16.840.1.113883.6.1" codeSystemName="LOINC" displayName="Osservazioni fisiche" />
          <title>Esame Obiettivo</title>
          <text>
            <paragraph>Paziente vigile, collaborante. Rachide: dolenzia alla palpazione L4-L5, Lasegue positivo a dx a 30 gradi. Forza muscolare conservata.</paragraph>
          </text>
        </section>
      </component>
      <component>
        <section ID="Diagnosi">
          <code code="29548-5" codeSystem="2.16.840.1.113883.6.1" codeSystemName="LOINC" displayName="Diagnosi" />
          <title>Diagnosi</title>
          <text>
            <paragraph>Lombalgia cronica con radicolopatia L5-S1.</paragraph>
          </text>
          <entry>
            <observation classCode="OBS" moodCode="EVN">
              <code code="29308-4" codeSystem="2.16.840.1.113883.6.1" codeSystemName="LOINC" displayName="Diagnosi" />
              <value xsi:type="CD" code="724.2" codeSystem="2.16.840.1.113883.6.103" codeSystemName="ICD9-CM" displayName="Lombalgia" />
            </observation>
          </entry>
        </section>
      </component>
      <component>
        <section ID="Conclusioni">
          <code code="55110-1" codeSystem="2.16.840.1.113883.6.1" codeSystemName="LOINC" displayName="Conclusioni" />
          <title>Conclusioni</title>
          <text>
            <paragraph>Si conferma la diagnosi di lombalgia cronica con radicolopatia. Indicata fisioterapia riabilitativa.</paragraph>
          </text>
        </section>
      </component>
      <component>
        <section ID="Suggerimenti_Medico_Prescrittore">
          <code code="62385-0" codeSystem="2.16.840.1.113883.6.1" codeSystemName="LOINC" displayName="Raccomandazioni" />
          <title>Suggerimenti per il Medico Prescrittore</title>
          <text>
            <paragraph>Si suggerisce rivalutazione neurologica se persistenza dei sintomi dopo 6 settimane di trattamento.</paragraph>
          </text>
        </section>
      </component>
      <component>
        <section ID="Accertamenti_e_Controlli_Consigliati">
          <code code="80615-8" codeSystem="2.16.840.1.113883.6.1" codeSystemName="LOINC" displayName="Follow-up consigliato" />
          <title>Accertamenti e Controlli Consigliati</title>
          <text>
            <paragraph>Controllo clinico tra 6 settimane. Se peggioramento, RMN rachide lombare.</paragraph>
          </text>
          <entry>
            <act classCode="ACT" moodCode="PRP">
              <code code="80615-8" codeSystem="2.16.840.1.113883.6.1" codeSystemName="LOINC" displayName="Follow-up consigliato" />
            </act>
          </entry>
        </section>
      </component>
      <component>
        <section ID="Terapia_Farmacologica_Consigliata">
          <code code="93341-6" codeSystem="2.16.840.1.113883.6.1" codeSystemName="LOINC" displayName="Farmaci consigliati" />
          <title>Terapia Farmacologica Consigliata</title>
          <text>
            <paragraph>Ibuprofene 400mg x 2/die per 7 giorni al bisogno. Miorilassante alla sera.</paragraph>
          </text>
          <entry>
            <substanceAdministration classCode="SBADM" moodCode="PRP">
              <effectiveTime xsi:type="IVL_TS">
                <low value="20260311" />
              </effectiveTime>
              <consumable>
                <manufacturedProduct>
                  <manufacturedMaterial>
                    <code code="M01AE01" codeSystem="2.16.840.1.113883.6.73" codeSystemName="ATC" displayName="Ibuprofene" />
                  </manufacturedMaterial>
                </manufacturedProduct>
              </consumable>
            </substanceAdministration>
          </entry>
        </section>
      </component>
      <component>
        <section ID="Confronto_con_Precedenti_Esami_Eseguiti">
          <code code="93126-1" codeSystem="2.16.840.1.113883.6.1" codeSystemName="LOINC" displayName="Confronto con precedenti esami eseguiti" />
          <title>Confronto con Precedenti Esami Eseguiti</title>
          <text>
            <paragraph>Rispetto ai precedenti esami si rileva stabilita del quadro clinico, senza segni di progressione.</paragraph>
          </text>
        </section>
      </component>
    </structuredBody>
  </component>
</ClinicalDocument>
